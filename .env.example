# LLM Council — environment configuration
# Copy to .env.local for server-side settings (optional for default Cursor mode)

# ── Cursor default mode (recommended) ─────────────────────────────────────────
# One-time setup: get a key from Cursor Dashboard → Integrations
# This is server-side only — never shown in the UI, never committed.
# When set, all council runs in "Cursor default" mode bill against your Cursor subscription.
CURSOR_API_KEY=

# Cursor model ids (see Cursor.models.list() or use "auto")
CURSOR_DEFAULT_MODEL=auto
CURSOR_CHAIRMAN_MODEL=auto

# ── Custom provider defaults (only used when user selects Custom in UI) ───────
# Users enter their own API keys in the browser session — not here.

# Optional global overrides for custom OpenAI-compatible providers
# DEFAULT_MODEL=gpt-4o-mini
# CHAIRMAN_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Per-member model overrides (any provider mode)
# SKEPTIC_MODEL=auto
# MARKET_ANALYST_MODEL=auto
# TECHNOLOGIST_MODEL=auto
# VISIONARY_MODEL=auto
# DEVILS_ADVOCATE_MODEL=auto
# PRAGMATIST_MODEL=auto
